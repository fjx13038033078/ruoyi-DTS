<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.ticket.mapper.BizPointsItemMapper">

    <resultMap type="com.ruoyi.ticket.domain.BizPointsItem" id="BizPointsItemResult">
        <id     property="itemId"         column="item_id"         />
        <result property="name"           column="name"           />
        <result property="pointsRequired" column="points_required" />
        <result property="stock"          column="stock"          />
        <result property="status"         column="status"         />
        <result property="createTime"     column="create_time"    />
    </resultMap>

    <sql id="selectBizPointsItemVo">
        select item_id, name, points_required, stock, status, create_time
        from biz_points_item
    </sql>

    <select id="selectBizPointsItemById" parameterType="Long" resultMap="BizPointsItemResult">
        <include refid="selectBizPointsItemVo"/>
        where item_id = #{itemId}
    </select>

    <select id="selectBizPointsItemList" parameterType="com.ruoyi.ticket.domain.BizPointsItem" resultMap="BizPointsItemResult">
        <include refid="selectBizPointsItemVo"/>
        <where>
            <if test="name != null and name != ''">
                AND name like concat('%', #{name}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
    </select>

    <insert id="insertBizPointsItem" parameterType="com.ruoyi.ticket.domain.BizPointsItem" useGeneratedKeys="true" keyProperty="itemId">
        insert into biz_points_item
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="pointsRequired != null">points_required,</if>
            <if test="stock != null">stock,</if>
            <if test="status != null">status,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="pointsRequired != null">#{pointsRequired},</if>
            <if test="stock != null">#{stock},</if>
            <if test="status != null">#{status},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateBizPointsItem" parameterType="com.ruoyi.ticket.domain.BizPointsItem">
        update biz_points_item
        <set>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="pointsRequired != null">points_required = #{pointsRequired},</if>
            <if test="stock != null">stock = #{stock},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        where item_id = #{itemId}
    </update>

    <delete id="deleteBizPointsItemById" parameterType="Long">
        delete from biz_points_item where item_id = #{itemId}
    </delete>

    <delete id="deleteBizPointsItemByIds" parameterType="Long">
        delete from biz_points_item where item_id in
        <foreach item="itemId" collection="array" open="(" separator="," close=")">
            #{itemId}
        </foreach>
    </delete>

</mapper>
